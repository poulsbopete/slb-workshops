#!/bin/bash
# Verify that the DB monitoring generator started and dashboards were deployed.

set -euo pipefail

PASS=0

# Check 1: generator process running
if pgrep -f db_otel_generator.py > /dev/null 2>&1; then
  echo "✓ Data generator is running"
  PASS=$((PASS + 1))
else
  echo "✗ Data generator not running"
fi

# Check 2: generator has sent data (log file exists and has content)
if [ -s /tmp/db-monitoring-logs/generator.log ]; then
  echo "✓ Generator log present"
  PASS=$((PASS + 1))
else
  echo "✗ Generator log missing or empty (check /tmp/db-monitoring-logs/generator.log)"
fi

# Check 3: at least one dashboard ID recorded
if [ -s /root/workshop/build/db-monitoring/dashboard-ids.txt ]; then
  echo "✓ Dashboards deployed: $(wc -l < /root/workshop/build/db-monitoring/dashboard-ids.txt) dashboard(s)"
  PASS=$((PASS + 1))
else
  echo "✗ No dashboard IDs found (check Kibana deployment)"
fi

# Pass if 2 out of 3 checks succeed (dashboards may lag)
if [ "$PASS" -ge 2 ]; then
  echo "CHECK PASS ($PASS/3)"
  exit 0
else
  echo "CHECK FAIL ($PASS/3) — run 'solve-es3-api' to retry"
  exit 1
fi
